{
  "name": "Tag Order",
  "module": "Tag Order",
  "doctype": "DocType",
  "document_type": "Document",
  "engine": "InnoDB",
  "naming_rule": "Expression",
  "autoname": "TAG.#####",
  "title_field": "client_name",
  "search_fields": "client_name,contact_name,email",
  "track_changes": 1,
  "allow_guest_to_view": 1,
  "fields": [
    {
      "fieldname": "contact_section",
      "fieldtype": "Section Break",
      "label": "Contact Information"
    },
    {
      "fieldname": "client_name",
      "fieldtype": "Data",
      "label": "Client Name",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "contact_name",
      "fieldtype": "Data",
      "label": "Contact Name",
      "reqd": 1
    },
    {
      "fieldname": "contact_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "email",
      "fieldtype": "Data",
      "label": "Email",
      "options": "Email",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "phone",
      "fieldtype": "Data",
      "label": "Phone",
      "options": "Phone",
      "reqd": 1
    },
    {
      "fieldname": "shipping_section",
      "fieldtype": "Section Break",
      "label": "Shipping"
    },
    {
      "fieldname": "address_to_ship",
      "fieldtype": "Small Text",
      "label": "Address To Ship",
      "reqd": 1
    },
    {
      "fieldname": "order_details_section",
      "fieldtype": "Section Break",
      "label": "Order Details"
    },
    {
      "fieldname": "order_type",
      "fieldtype": "Select",
      "label": "Order Type",
      "options": "\nInternal\nExternal",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "ink_color",
      "fieldtype": "Select",
      "label": "Ink Color",
      "options": "\nBlack\nRed\nBlue\nGreen\nCustom Color",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "order_details_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "number_of_rolls",
      "fieldtype": "Int",
      "label": "Number of Rolls",
      "reqd": 1,
      "non_negative": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "starting_number",
      "fieldtype": "Data",
      "label": "Starting Number",
      "reqd": 1
    },
    {
      "fieldname": "tag_text_section",
      "fieldtype": "Section Break",
      "label": "Tag Text"
    },
    {
      "fieldname": "line_1",
      "fieldtype": "Data",
      "label": "LINE 1",
      "reqd": 1
    },
    {
      "fieldname": "tag_text_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "line_2",
      "fieldtype": "Data",
      "label": "LINE 2",
      "reqd": 1
    },
    {
      "fieldname": "dates_section",
      "fieldtype": "Section Break",
      "label": "Dates & Pricing"
    },
    {
      "fieldname": "required_date",
      "fieldtype": "Date",
      "label": "Required Date",
      "reqd": 1
    },
    {
      "fieldname": "order_date",
      "fieldtype": "Date",
      "label": "Order Date",
      "default": "Today",
      "read_only": 1
    },
    {
      "fieldname": "dates_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "total_price",
      "fieldtype": "Currency",
      "label": "Total Price",
      "read_only": 1,
      "description": "$175 per roll"
    },
    {
      "fieldname": "shipped_date",
      "fieldtype": "Date",
      "label": "Shipped Date",
      "read_only": 1
    },
    {
      "fieldname": "optional_section",
      "fieldtype": "Section Break",
      "label": "Optional Information"
    },
    {
      "fieldname": "po_number",
      "fieldtype": "Data",
      "label": "PO# (Optional)"
    },
    {
      "fieldname": "optional_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "state_tax_exemption",
      "fieldtype": "Data",
      "label": "State Tax Exemption # (Optional)"
    },
    {
      "fieldname": "terms_section",
      "fieldtype": "Section Break",
      "label": "Terms"
    },
    {
      "fieldname": "agree_to_terms",
      "fieldtype": "Check",
      "label": "I agree to the terms to proceed",
      "reqd": 1
    },
    {
      "fieldname": "internal_section",
      "fieldtype": "Section Break",
      "label": "Internal",
      "collapsible": 1
    },
    {
      "fieldname": "assigned_to",
      "fieldtype": "Link",
      "label": "Assigned To",
      "options": "User"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "\nSubmitted\nIn Review\nPrinting\nShipped\nComplete\nCancelled",
      "default": "Submitted",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "internal_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    },
    {
      "fieldname": "notification_log",
      "fieldtype": "Small Text",
      "label": "Notification Log",
      "hidden": 1
    },
    {
      "fieldname": "work_order_section",
      "fieldtype": "Section Break",
      "label": "Work Order",
      "depends_on": "eval:doc.status=='Complete'",
      "collapsible": 1
    },
    {
      "fieldname": "wo_project_id",
      "fieldtype": "Data",
      "label": "Project ID"
    },
    {
      "fieldname": "wo_project_name",
      "fieldtype": "Data",
      "label": "Project Name"
    },
    {
      "fieldname": "wo_sales_rep",
      "fieldtype": "Data",
      "label": "Sales Representative"
    },
    {
      "fieldname": "wo_column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "wo_project_manager",
      "fieldtype": "Data",
      "label": "Project Manager"
    },
    {
      "fieldname": "wo_timesheet_approver",
      "fieldtype": "Data",
      "label": "Timesheet Approver"
    },
    {
      "fieldname": "wo_contract_section",
      "fieldtype": "Section Break",
      "label": "Contract Details",
      "depends_on": "eval:doc.status=='Complete'"
    },
    {
      "fieldname": "wo_contract_type",
      "fieldtype": "Select",
      "label": "Contract Type",
      "options": "\nHardware\nSoftware\nService"
    },
    {
      "fieldname": "wo_revenue_type",
      "fieldtype": "Select",
      "label": "Revenue Type",
      "options": "\nRevenue earned as labor incurred\nFixed fee"
    },
    {
      "fieldname": "wo_fye",
      "fieldtype": "Data",
      "label": "FYE"
    },
    {
      "fieldname": "wo_contract_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "wo_cap_critical_rates",
      "fieldtype": "Data",
      "label": "CAP/Critical Rates"
    },
    {
      "fieldname": "wo_est_end_date",
      "fieldtype": "Date",
      "label": "Est. End Date"
    },
    {
      "fieldname": "wo_date_due_solution_delivery",
      "fieldtype": "Date",
      "label": "Date Due to Solution Delivery"
    },
    {
      "fieldname": "wo_budget_section",
      "fieldtype": "Section Break",
      "label": "Budget & Hours",
      "depends_on": "eval:doc.status=='Complete'"
    },
    {
      "fieldname": "wo_expenses_budget",
      "fieldtype": "Currency",
      "label": "Expenses Budget"
    },
    {
      "fieldname": "wo_project_services_budget",
      "fieldtype": "Currency",
      "label": "Project Services Budget"
    },
    {
      "fieldname": "wo_budget_column_break",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "wo_total_hours",
      "fieldtype": "Float",
      "label": "Total Project Hours"
    },
    {
      "fieldname": "wo_appraiser_hours",
      "fieldtype": "Float",
      "label": "Appraiser Hours"
    },
    {
      "fieldname": "wo_solution_delivery_hours",
      "fieldtype": "Float",
      "label": "Solution Delivery Hours"
    },
    {
      "fieldname": "wo_accounting_section",
      "fieldtype": "Section Break",
      "label": "Accounting Status",
      "depends_on": "eval:doc.status=='Complete'"
    },
    {
      "fieldname": "wo_sent_to_accounting",
      "fieldtype": "Check",
      "label": "Sent to Accounting",
      "read_only": 1
    },
    {
      "fieldname": "wo_sent_date",
      "fieldtype": "Datetime",
      "label": "Sent Date",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 0,
      "cancel": 0,
      "email": 1,
      "print": 1,
      "export": 1
    },
    {
      "role": "Agent",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "email": 1,
      "print": 1,
      "export": 1
    },
    {
      "role": "Guest",
      "read": 0,
      "write": 0,
      "create": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
